# docker-compose.override.yml.example
#
# Copy this file to docker-compose.override.yml to activate optional features.
# docker-compose.override.yml is gitignored and must NEVER be committed.
#
# ⚠️  SECURITY WARNING: Mounting the Docker socket grants the container
#     root-equivalent access to the host Docker daemon. Only enable this
#     if you understand the implications and need to run Lando or Docker
#     commands from inside the Code Server terminal.

services:
  code-server:
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    # If using Docker socket access, the coder user may need to be in the
    # docker group. You can add this to entrypoint.sh or run:
    #   sudo groupadd -g <host-docker-gid> docker
    #   sudo usermod -aG docker coder
