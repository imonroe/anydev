# docker-compose.override.yml.example
#
# Copy this file to docker-compose.override.yml to activate optional features.
# Uncomment only the sections you need.
# docker-compose.override.yml is gitignored and must NEVER be committed.
#
# Note: /var/run/docker.sock, Docker CLI, and Lando CLI are already built into
# the container and docker-compose.yml. No override is needed for those.

services:
  code-server:
    volumes:
      # --- Acquia Cloud credentials ---
      # Mount your host ~/.acquia directory (read-only) for Acquia CLI access.
      # Only enable if ~/.acquia exists on the host.
      #- ~/.acquia:/home/coder/.acquia:ro
