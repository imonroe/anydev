# anydev environment configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ---------- Code Server ----------

# Host port for the Code Server web UI
CODE_SERVER_PORT=8080

# Password for the Code Server login screen (required)
CODE_SERVER_PASSWORD=

# ---------- Host Paths ----------

# Absolute path to your home directory on the host (e.g. /home/ian).
# Used to create a matching symlink inside the container so tools like Lando
# that call os.homedir() generate Docker bind-mount paths the daemon can resolve.
HOST_HOME_DIR=/home/your-username

# Absolute path to your code directory on the host
# This is mounted read/write into the container at /home/coder/code
HOST_CODE_DIR=/home/your-username/code

# ---------- User Identity ----------

# Must match your WSL2 user's UID/GID so file ownership is correct
# Find with: id -u  and  id -g
USER_UID=1000
USER_GID=1000

# GID of the docker group on the host, so the container can access /var/run/docker.sock
# Find with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=1001

# ---------- Git ----------

# Used to configure git inside the container
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# ---------- SSH ----------

# Your host ~/.ssh directory is mounted read-only into the container.
# No configuration needed — just ensure your SSH keys exist at ~/.ssh
# on the host and git push/pull will work inside the container.

# ---------- GitHub CLI ----------

# Personal access token for the GitHub CLI (gh).
# Create one at https://github.com/settings/tokens
# Required scopes: repo, read:org (adjust to your needs)
GITHUB_TOKEN=

# ---------- Claude Code ----------

# Claude Code authenticates via OAuth (Claude Max subscription).
# Run "claude" on the host first to complete browser login, then these
# paths are bind-mounted into the container automatically.
# Override only if your credentials live somewhere non-standard.
# IMPORTANT: Use absolute paths here — Docker Compose does not expand ~ from .env values.
CLAUDE_CONFIG_DIR=/home/your-username/.claude
CLAUDE_CREDENTIALS=/home/your-username/.claude.json

# -- Additional Environment Variables --
ACQUIA_KEY=
ACQUIA_SECRET=
ACSF_API_KEY= 
ACSF_USERNAME=

OPENAI_KEY=
HOMEASSISTANT_WEBHOOK=

# Webhook URL called when Claude Code finishes a task (used by claude-config/settings.json Stop hook)
CLAUDE_STOP_WEBHOOK_URL=

# ---------- Vault ----------
VAULT_ADDR=
VAULT_USER=
VAULT_PASS=